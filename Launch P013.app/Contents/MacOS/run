#!/bin/bash
# Launcher for Launch P013.app.
#
# macOS TCC (Privacy & Security) blocks Finder-launched app bundles from
# reading the study folder when it lives under ~/Desktop. Rather than fight
# TCC for an ad-hoc-signed bundle, we delegate to Terminal, which has
# already been granted the folder access needed to run `uv`. The net UX is
# still "double-click an icon": Terminal pops up, the GUI appears.
#
# The script must be bash-only and resolve the repo root from its own
# bundle path so the .app can be moved (Dock, Desktop shortcut, etc.).

set -u

BUNDLE_EXEC_DIR="$(cd "$(dirname "$0")" 2>/dev/null && pwd)"
REPO_ROOT="$(cd "$BUNDLE_EXEC_DIR/../../.." 2>/dev/null && pwd)"

if [ -z "$REPO_ROOT" ] || [ ! -d "$REPO_ROOT" ]; then
    /usr/bin/osascript -e "display alert \"Launch P013\" message \"Could not resolve repo root from bundle path.\""
    exit 2
fi

# Hand off to launch.command via Terminal.app. `open -a Terminal <file>`
# opens the script in a new Terminal window (or tab) and executes it with
# Terminal's permission set.
if [ ! -x "$REPO_ROOT/launch.command" ]; then
    /usr/bin/osascript -e "display alert \"Launch P013\" message \"launch.command not found at $REPO_ROOT. Re-pull the repo or check file permissions.\""
    exit 2
fi

open -a Terminal "$REPO_ROOT/launch.command"
exit 0
