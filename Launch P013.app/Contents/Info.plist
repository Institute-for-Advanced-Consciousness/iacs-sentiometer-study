<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleName</key>
    <string>Launch P013</string>
    <key>CFBundleDisplayName</key>
    <string>Launch P013</string>
    <key>CFBundleIdentifier</key>
    <string>org.iacscience.p013-launcher</string>
    <key>CFBundleVersion</key>
    <string>1.0</string>
    <key>CFBundleShortVersionString</key>
    <string>1.0</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleExecutable</key>
    <string>run</string>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>
    <key>LSMinimumSystemVersion</key>
    <string>12.0</string>
    <key>NSHighResolutionCapable</key>
    <true/>
    <!-- TCC usage descriptions so Finder-launched runs trigger the
         "Allow this app to access your Desktop/Documents/Downloads" prompt
         on first launch. Without these, macOS silently refuses access to
         protected folders and Python blows up with EPERM trying to read
         .venv/pyvenv.cfg. -->
    <key>NSDesktopFolderUsageDescription</key>
    <string>Launch P013 reads the study repo, venv, and data from the folder it lives in.</string>
    <key>NSDocumentsFolderUsageDescription</key>
    <string>Launch P013 reads the study repo, venv, and data from the folder it lives in.</string>
    <key>NSDownloadsFolderUsageDescription</key>
    <string>Launch P013 reads the study repo, venv, and data from the folder it lives in.</string>
    <key>NSRemovableVolumesUsageDescription</key>
    <string>Launch P013 reads the study repo, venv, and data from the folder it lives in.</string>
</dict>
</plist>
